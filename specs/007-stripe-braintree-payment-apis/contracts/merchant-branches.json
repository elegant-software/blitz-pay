{
  "contract": "Merchant Branch Management",
  "version": "v1",
  "endpoints": [
    {
      "id": "create-branch",
      "method": "POST",
      "path": "/v1/merchants/{merchantId}/branches",
      "description": "Creates a new MerchantBranch under the given merchant. Branch may carry its own Stripe/Braintree credentials that override the merchant-level defaults.",
      "request": {
        "contentType": "application/json",
        "pathParams": {
          "merchantId": {
            "type": "string",
            "format": "uuid",
            "required": true,
            "description": "ID of the owning merchant (MerchantApplication.id)"
          }
        },
        "body": {
          "name": {
            "type": "string",
            "required": true,
            "description": "Human-readable branch name.",
            "example": "Downtown Branch"
          },
          "contactFullName": {
            "type": "string",
            "required": false,
            "description": "Operational branch contact name."
          },
          "contactEmail": {
            "type": "string",
            "required": false,
            "description": "Operational branch contact email."
          },
          "contactPhoneNumber": {
            "type": "string",
            "required": false,
            "description": "Operational branch contact phone number."
          },
          "activePaymentChannels": {
            "type": "array",
            "required": false,
            "items": {
              "type": "string",
              "enum": ["PAYPAL", "STRIPE", "TRUELAYER"]
            },
            "description": "Branch-level enabled payment channels."
          }
        }
      },
      "responses": {
        "201": {
          "description": "Branch created successfully",
          "contentType": "application/json",
          "body": {
            "id": { "type": "string", "format": "uuid" },
            "merchantId": { "type": "string", "format": "uuid" },
            "name": { "type": "string" },
            "active": { "type": "boolean" },
            "contactFullName": { "type": "string" },
            "contactEmail": { "type": "string" },
            "contactPhoneNumber": { "type": "string" },
            "activePaymentChannels": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["PAYPAL", "STRIPE", "TRUELAYER"]
              }
            },
            "createdAt": { "type": "string", "format": "date-time" },
            "updatedAt": { "type": "string", "format": "date-time" }
          }
        },
        "400": {
          "description": "Invalid request — name missing or blank",
          "body": { "error": { "type": "string" } }
        },
        "404": {
          "description": "Merchant not found",
          "body": { "error": { "type": "string", "example": "Merchant not found" } }
        }
      },
      "security": {
        "note": "Payment provider credentials are platform-managed; merchant branch APIs only select the active payment channel."
      }
    },
    {
      "id": "list-branches",
      "method": "GET",
      "path": "/v1/merchants/{merchantId}/branches",
      "description": "Lists all active branches for the given merchant.",
      "request": {
        "pathParams": {
          "merchantId": {
            "type": "string",
            "format": "uuid",
            "required": true
          }
        }
      },
      "responses": {
        "200": {
          "description": "List of active branches",
          "body": {
            "branches": {
              "type": "array",
              "items": "BranchResponse (same shape as CREATE 201 response)"
            }
          }
        },
        "404": {
          "description": "Merchant not found",
          "body": { "error": { "type": "string" } }
        }
      }
    }
  ]
}
